{
    "name": "globus-studio/async",
    "description": "Promise-style asynchronous programming for PHP, built on Revolt fibers and the event loop.",
    "type": "library",
    "license": "MIT",
    "keywords": ["async", "await", "promise", "fiber", "revolt", "concurrency", "event-loop"],
    "authors": [
        {
            "name": "GLOBUS.studio",
            "email": "admin@globus.studio"
        }
    ],
    "require": {
        "php": ">=8.1",
        "revolt/event-loop": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "GlobusStudio\\Async\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "GlobusStudio\\Async\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
